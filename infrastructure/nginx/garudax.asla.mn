# GarudaX Platform — subdomain-separated architecture
# Subdomains: garudax.asla.mn (API), trade.garudax.asla.mn, admin.garudax.asla.mn, demo.garudax.asla.mn

# R031 — brute-force throttle for the demo portal login POST (per client IP).
# 10 req/min sustained; burst of 5 absorbed immediately (covers password typos),
# then throttled. Excess returns 429. Zone holds ~160k IPs in 10m.
limit_req_zone $binary_remote_addr zone=demo_login:10m rate=10r/m;

# CORS map — allow all GarudaX subdomains
map $http_origin $cors_origin {
    default "";
    "https://garudax.asla.mn" "https://garudax.asla.mn";
    "https://admin.garudax.asla.mn" "https://admin.garudax.asla.mn";
    "https://trade.garudax.asla.mn" "https://trade.garudax.asla.mn";
    "https://demo.garudax.asla.mn" "https://demo.garudax.asla.mn";
}

# ── admin.garudax.asla.mn — Admin Dashboard ──────────────────────────────
server {
    server_name admin.garudax.asla.mn;

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header 'Access-Control-Allow-Origin' $cors_origin always;
        add_header 'Access-Control-Allow-Headers' 'Authorization, Content-Type, X-GarudaX-Tenant' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, PATCH, OPTIONS' always;
        add_header 'Access-Control-Max-Age' 86400 always;
    }

    location /api/v1/ws/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    location /healthz { proxy_pass http://127.0.0.1:8080; }
    location /readyz  { proxy_pass http://127.0.0.1:8080; }

    location / {
        proxy_pass http://127.0.0.1:13001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/admin.garudax.asla.mn-0002/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/admin.garudax.asla.mn-0002/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

# ── trade.garudax.asla.mn — Trading Web UI ───────────────────────────────
server {
