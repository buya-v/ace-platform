# ACE Platform — Environment Variables
# Copy to .env and adjust values for your environment.
# docker compose automatically loads .env from the project root.

# ─── PostgreSQL / TimescaleDB ────────────────────────────────────────
POSTGRES_USER=ace
POSTGRES_PASSWORD=ace_dev_password
POSTGRES_DB=ace
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Kafka / Zookeeper ──────────────────────────────────────────────
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# ─── Auth / JWT ──────────────────────────────────────────────────────
# IMPORTANT: Change this in production!
AUTH_JWT_SIGNING_KEY=ace-dev-jwt-signing-key-change-in-production

# ─── Instruments ─────────────────────────────────────────────────────
# Comma-separated list of instrument symbols to register on startup.
INSTRUMENTS=WHT-HRW-2026M07-UB

# ─── Domains / TLS ──────────────────────────────────────────────────
ACE_DOMAIN=ace.asla.mn
DEMO_DOMAIN=demo.ace.asla.mn
TLS_EMAIL=admin@asla.mn

# ─── CORS ───────────────────────────────────────────────────────────
# Additional allowed origins (comma-separated). The defaults
# (https://ace.asla.mn, https://demo.ace.asla.mn) are always included.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
