# ── ACE Platform — Local Development Environment ──────────────────────
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ── PostgreSQL + TimescaleDB ──────────────────────────────────────────
POSTGRES_USER=ace_admin
POSTGRES_PASSWORD=ace_dev_password
POSTGRES_DB=ace_platform
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_PORT=9094

# ── MinIO (S3-compatible) ─────────────────────────────────────────────
MINIO_ROOT_USER=ace_minio
MINIO_ROOT_PASSWORD=ace_minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Application ──────────────────────────────────────────────────────
APP_ENV=development
JWT_SECRET=dev-jwt-secret-change-in-prod

# ── Service DB Passwords (one per microservice role) ──────────────────
EXCHANGE_SVC_PASSWORD=exchange_dev_pass
AUTH_SVC_PASSWORD=auth_dev_pass
CLEARING_SVC_PASSWORD=clearing_dev_pass
COMPLIANCE_SVC_PASSWORD=compliance_dev_pass
WAREHOUSE_SVC_PASSWORD=warehouse_dev_pass
ANALYTICS_SVC_PASSWORD=analytics_dev_pass
