# GarudaX Platform — Environment Variables
# Copy to .env and adjust values for your environment.
# docker compose automatically loads .env from the project root.

# ─── PostgreSQL / TimescaleDB ────────────────────────────────────────
POSTGRES_USER=garudax
POSTGRES_PASSWORD=garudax_dev_password
POSTGRES_DB=garudax
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Kafka / Zookeeper ──────────────────────────────────────────────
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# ─── Auth / JWT ──────────────────────────────────────────────────────
# IMPORTANT: Change this in production!
AUTH_JWT_SIGNING_KEY=garudax-dev-jwt-signing-key-change-in-production

# ─── Instruments ─────────────────────────────────────────────────────
# Comma-separated list of instrument symbols to register on startup.
INSTRUMENTS=WHT-HRW-2026M07-UB

# ─── Domains / TLS ──────────────────────────────────────────────────
GARUDAX_DOMAIN=garudax.asla.mn
ADMIN_DOMAIN=admin.garudax.asla.mn
TRADE_DOMAIN=trade.garudax.asla.mn
DEMO_DOMAIN=demo.garudax.asla.mn
TLS_EMAIL=admin@asla.mn

# ─── Admin Bot ─────────────────────────────────────────────────────
BOT_ADMIN_EMAIL=admin@garudax.mn
BOT_ADMIN_PASSWORD=Adm1n@GarudaX!
# OpenAI API key for LLM-powered bot features (optional)
# OPENAI_API_KEY=sk-...

# ─── CORS ───────────────────────────────────────────────────────────
# Additional allowed origins (comma-separated). The defaults
# (https://garudax.asla.mn, https://demo.garudax.asla.mn) are always included.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
